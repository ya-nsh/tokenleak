{
  "name": "tokenleak",
  "private": true,
  "packageManager": "bun@1.0.7",
  "workspaces": ["packages/*", "tooling/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "check": "turbo run check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "bundle": "bun scripts/build-npm.ts",
    "prepublish": "bun run build && bun run bundle && bun scripts/prepare-publish.ts",
    "publish:npm": "bun run prepublish && cd dist && npm publish"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
